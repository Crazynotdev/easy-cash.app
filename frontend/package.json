{
  "name": "easycash-africa",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint srx --ext .ts,.tsx --fix",
    "format": "prettier --write \"srx/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit",
    "build:android": "eas build -p android --profile production",
    "build:ios": "eas build -p ios --profile production",
    "build:web": "expo build:web",
    "deploy:web": "firebase deploy --only hosting",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.18.2",
    "@react-native-picker/picker": "2.4.10",
    "@react-navigation/bottom-tabs": "^6.5.8",
    "@react-navigation/drawer": "^6.6.3",
    "@react-navigation/native": "^6.1.7",
    "@react-navigation/native-stack": "^6.9.13",
    "@react-navigation/stack": "^6.3.17",
    "expo": "~49.0.11",
    "expo-ads-admob": "~12.4.0",
    "expo-application": "~5.3.0",
    "expo-auth-session": "~5.0.2",
    "expo-av": "~13.4.1",
    "expo-blur": "~12.4.1",
    "expo-camera": "~13.4.1",
    "expo-constants": "~14.4.2",
    "expo-crypto": "~12.4.1",
    "expo-device": "~5.4.0",
    "expo-file-system": "~15.4.2",
    "expo-font": "~11.4.0",
    "expo-haptics": "~12.4.0",
    "expo-image-picker": "~14.3.2",
    "expo-linear-gradient": "~12.3.0",
    "expo-linking": "~5.0.2",
    "expo-local-authentication": "~13.4.1",
    "expo-localization": "~14.3.0",
    "expo-notifications": "~0.20.1",
    "expo-random": "~13.4.0",
    "expo-secure-store": "~12.3.1",
    "expo-splash-screen": "~0.20.5",
    "expo-status-bar": "~1.6.0",
    "expo-store-review": "~6.4.0",
    "expo-updates": "~0.18.12",
    "expo-web-browser": "~12.3.2",
    "firebase": "^10.5.0",
    "lottie-react-native": "5.1.6",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.47.0",
    "react-native": "0.72.5",
    "react-native-gesture-handler": "~2.12.0",
    "react-native-paper": "^5.10.6",
    "react-native-qrcode-svg": "^6.2.0",
    "react-native-reanimated": "~3.3.0",
    "react-native-safe-area-context": "4.6.3",
    "react-native-screens": "~3.22.1",
    "react-native-svg": "13.9.0",
    "react-native-toast-message": "^2.1.6",
    "react-native-web": "~0.19.6",
    "react-native-webview": "13.2.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.3.0",
    "@types/jest": "^29.5.6",
    "@types/react": "~18.2.14",
    "@types/react-native": "~0.72.3",
    "@typescript-eslint/eslint-plugin": "^6.8.0",
    "@typescript-eslint/parser": "^6.8.0",
    "babel-jest": "^29.2.1",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint": "^8.51.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.2.1",
    "jest-expo": "^49.0.0",
    "patch-package": "^8.0.0",
    "prettier": "^3.0.3",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.2.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-vector-icons|react-native-svg|react-native-reanimated|@react-navigation/.*)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@components/(.*)$": "<rootDir>/srx/components/$1",
      "^@screens/(.*)$": "<rootDir>/srx/screens/$1",
      "^@services/(.*)$": "<rootDir>/srx/services/$1",
      "^@hooks/(.*)$": "<rootDir>/srx/hooks/$1",
      "^@context/(.*)$": "<rootDir>/srx/context/$1",
      "^@utils/(.*)$": "<rootDir>/srx/utils/$1",
      "^@types/(.*)$": "<rootDir>/srx/types/$1",
      "^@config/(.*)$": "<rootDir>/srx/config/$1",
      "^@navigation/(.*)$": "<rootDir>/src/navigation/$1",
      "^@assets/(.*)$": "<rootDir>/assets/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/index.{ts,tsx}",
      "!src/types/**/*"
    ]
  },
  "private": true
}
